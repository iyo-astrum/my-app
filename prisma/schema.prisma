// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 収支を記録するためのモデル
model Transaction {
  id          Int      @id @default(autoincrement())
  type        String   // "income" (収入) か "expense" (支出)
  date        DateTime // 収支が発生した日付
  amount      Int      // 額面
  category    String   // 経費の区分（「食費」「交通費」など）
  memo        String?  // 詳細（メモ）
  receiptUrl  String?  // 証憑画像の保存先
  createdAt   DateTime @default(now()) // 登録日時
}

// カテゴリを管理するためのモデル
model Category {
  id   Int    @id @default(autoincrement())
  name String @unique
}
