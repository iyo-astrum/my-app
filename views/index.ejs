<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>収支管理アプリ</title>
    <style>
        body { font-family: sans-serif; max-width: 600px; margin: 20px auto; padding: 0 15px; line-height: 1.6; color: #333; }
        .box { padding: 15px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #ddd; background: #fff; }
        
        /* 残高表示のスタイル */
        .balance-box { background: #f8f9fa; text-align: center; border: 2px solid #e9ecef; }
        .balance-amount { font-size: 2.2em; font-weight: bold; color: #2c3e50; }

        /* AIセクションのスタイル */
        .ai-box { background: #e3f2fd; border-color: #bbdefb; }
        .ai-title { color: #1565c0; margin-top: 0; display: flex; align-items: center; gap: 8px; }

        /* フォームのスタイル */
        .form-group { margin-bottom: 15px; }
        label { display: block; font-weight: bold; margin-bottom: 5px; font-size: 0.9em; }
        input, select, textarea { width: 100%; padding: 10px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; font-size: 1em; }
        button { width: 100%; padding: 12px; background: #2196f3; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 1em; font-weight: bold; }
        button:hover { background: #1976d2; }

        /* カテゴリ追加用の小さなフォーム */
        .cat-add-form { display: flex; gap: 8px; }
        .cat-add-form input { flex: 1; }
        .cat-add-form button { width: auto; padding: 0 15px; background: #78909c; }

        /* 履歴テーブルのスタイル */
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { border-bottom: 1px solid #eee; padding: 12px 8px; text-align: left; }
        th { background: #fdfdfd; font-size: 0.9em; color: #666; }
        .income { color: #2e7d32; font-weight: bold; }
        .expense { color: #d32f2f; font-weight: bold; }
        
        /* 詳細へのリンク */
        .detail-link { text-decoration: none; color: #1976d2; font-weight: bold; }
        .detail-link:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <h1>収支管理</h1>

    <!-- 1. 現在の残高表示 -->
    <div class="box balance-box">
        <div style="font-size: 0.9em; color: #666;">現在の所持金</div>
        <div class="balance-amount">¥ <%= balance.toLocaleString() %></div>
    </div>

    <!-- 2. AIレシート解析セクション -->
    <div class="box ai-box">
        <h3 class="ai-title">📷 AIレシート読み取り</h3>
        <p style="font-size: 0.85em; color: #546e7a; margin-bottom: 10px;">
            レシートの写真をアップロードするとAIが自動で内容を判別します
        </p>
        <form action="/ai-parse-image" method="post" enctype="multipart/form-data">
            <div class="form-group">
                <input type="file" name="receipt" accept="image/*" required>
            </div>
            <button type="submit" style="background: #1565c0;">画像を解析して記録</button>
        </form>
    </div>

    <!-- 3. 手動入力フォーム -->
    <div class="box">
        <h3>手動で記録</h3>
        <form action="/transactions" method="post">
            <div class="form-group">
                <label>区分</label>
                <select name="type">
                    <option value="expense">支出 (-)</option>
                    <option value="income">収入 (+)</option>
                </select>
            </div>
            <div class="form-group">
                <label>金額 (円)</label>
                <input type="number" name="amount" placeholder="例: 1200" required>
            </div>
            <div class="form-group">
                <label>カテゴリ</label>
                <select name="category" required>
                    <option value="" disabled selected>選択してください</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat.name %>"><%= cat.name %></option>
                    <% }) %>
                </select>
            </div>
            <div class="form-group">
                <label>日付</label>
                <input type="date" name="date" value="<%= new Date().toISOString().split('T')[0] %>" required>
            </div>
            <button type="submit">記録する</button>
        </form>
    </div>

    <!-- 4. カテゴリ管理（追加） -->
    <div class="box" style="border-style: dashed;">
        <label>カテゴリを増やす</label>
        <form action="/categories" method="post" class="cat-add-form">
            <input type="text" name="name" placeholder="新しいカテゴリ名" required>
            <button type="submit">追加</button>
        </form>
    </div>

    <!-- 5. 履歴一覧 -->
    <h3>履歴一覧</h3>
    <table>
        <thead>
            <tr>
                <th>日付</th>
                <th>カテゴリ</th>
                <th>金額</th>
            </tr>
        </thead>
        <tbody>
            <% if (transactions.length === 0) { %>
                <tr><td colspan="3" style="text-align: center; color: #999; padding: 20px;">履歴がありません</td></tr>
            <% } %>
            <% transactions.forEach(t => { %>
                <tr>
                    <td>
                        <!-- 日付をクリックすると詳細ページへ飛ぶのじゃ -->
                        <a href="/transactions/<%= t.id %>" class="detail-link">
                            <%= new Date(t.date).toLocaleDateString('ja-JP') %>
                        </a>
                    </td>
                    <td><%= t.category %></td>
                    <td class="<%= t.type %>">
                        <%= t.type === 'income' ? '+' : '-' %> ¥ <%= t.amount.toLocaleString() %>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <footer style="margin-top: 40px; text-align: center; font-size: 0.8em; color: #bbb;">
        &copy; わしの収支アプリ 2026
    </footer>
</body>
</html>
